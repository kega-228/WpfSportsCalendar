<Window x:Class="WpfSportsCalendar.Windows.UnsubscribeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WpfSportsCalendar.Windows"
        mc:Ignorable="d"
        FontFamily="Segoe UI Variable Text"
        Title="Мої підписки" Height="450" Width="400"
        Background="#1E2330" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Керування підписками" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <ListBox Grid.Row="1" x:Name="SubscriptionsListBox" Background="Transparent" BorderThickness="0" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalAlignment="Center">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2A3144" CornerRadius="10" Margin="0,0,0,10" Padding="12,10" Width="340">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="White" FontSize="15" FontWeight="Medium" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>

                            <Button Grid.Column="1" Content="Видалити" 
                                    Background="#EF4444" Foreground="White" FontWeight="SemiBold"
                                    Padding="12,6" BorderThickness="0"
                                    Tag="{Binding Id}" Click="UnsubscribeButton_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>