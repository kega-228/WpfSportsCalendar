<Window x:Class="WpfSportsCalendar.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfSportsCalendar"
        FontFamily="Segoe UI Variable Text"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="450"
        ResizeMode="NoResize">
    <StackPanel Margin="10">
        <TextBlock FontSize="24" TextAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,10" x:Name="WelcomeText">Ласкаво просимо, {name}</TextBlock>
        
        <Button Width="410" Height="200" Margin="0,0,0,15">
            
        </Button>
        
        <Button Width="410" Height="200" Margin="0,0,0,15">
            
        </Button>
        
        <Button Width="410" Height="200" Margin="0,0,0,15">
            
        </Button>
        
        <UniformGrid Rows="1" Width="410" Height="60">
            <Button Content="Підписатися" Margin="0,0,10,0" Width="125" Height="50" HorizontalAlignment="Left" Click="SubscribeButton_Click"/> 
            
            <Button Content="Матчі" Margin="0,0,0,0" Width="125" Height="50" HorizontalAlignment="Center"/>
            
            <Button Content="Відписатися" Margin="10,0,0,0" Width="125" Height="50" HorizontalAlignment="Right"/>
        </UniformGrid>
    </StackPanel>
</Window>
