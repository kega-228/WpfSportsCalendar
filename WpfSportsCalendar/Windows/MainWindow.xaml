<Window x:Class="WpfSportsCalendar.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfSportsCalendar"
        FontFamily="Segoe UI Variable Text"
        mc:Ignorable="d"
        Title="MainWindow" Height="660" Width="450"
        ResizeMode="NoResize">
    <StackPanel Margin="10">
        <TextBlock FontSize="24" TextAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,10" x:Name="WelcomeText">Ласкаво просимо, {name}</TextBlock>
        
        <ItemsControl x:Name="MatchesItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Azure" BorderThickness="1" CornerRadius="12" Margin="0,0,0,15" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding DateText}" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                                    <Border CornerRadius="8" Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Center" Background="#F1F5F9">
                                        <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#64748B"/>
                                    </Border>
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{Binding HomeTeamLogo}" Width="50" Height="50" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding HomeTeamName}" FontSize="13" FontWeight="Medium" Margin="0,5,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding ScoreOrTime}" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0"/>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{Binding AwayTeamLogo}" Width="50" Height="50" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding AwayTeamName}" FontSize="13" FontWeight="Medium" Margin="0,5,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        
        <UniformGrid Rows="1" Width="410" Height="60">
            <Button Content="Підписатися" Margin="0,0,10,0" Width="125" Height="50" HorizontalAlignment="Left" Click="SubscribeButton_Click"/> 
            
            <Button Content="Матчі" Margin="0,0,0,0" Width="125" Height="50" HorizontalAlignment="Center"/>
            
            <Button Content="Відписатися" Margin="10,0,0,0" Width="125" Height="50" HorizontalAlignment="Right" Click="UnsubscribeButton_Click"/>
        </UniformGrid>
    </StackPanel>
</Window>
