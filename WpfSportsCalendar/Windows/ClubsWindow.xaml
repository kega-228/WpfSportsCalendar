<Window x:Class="WpfSportsCalendar.Windows.ClubsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WpfSportsCalendar.Windows"
        mc:Ignorable="d"
        Title="ClubsWindow" Height="500" Width="450">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5">Знайти футбольний клуб</TextBlock>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox Grid.Column="0" x:Name="SearchInput" Height="35" 
                         VerticalContentAlignment="Center" Margin="0,0,10,0"
                         KeyDown="SearchInput_KeyDown"/>
                
                <Button Grid.Column="1" Content="Пошук" Width="80" Height="35" 
                        Click="SearchButton_Click" IsDefault="True"/>
            </Grid>
        </StackPanel>

        <ListBox Grid.Row="1" x:Name="ClubsListBox" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Width="340" Margin="5">
                        <Image Source="{Binding Logo}" Width="32" Height="32" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Medium"/>
                            <TextBlock Text="{Binding Country}" FontSize="12" Foreground="Gray"/>
                        </StackPanel>
                        <Button Content="Підписатися" 
                                HorizontalAlignment="Right" 
                                Padding="10,5" 
                                Tag="{Binding Id}" 
                                Click="SubscribeClubButton_Click"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
